  m_Name: 
  m_EditorClassIdentifier: '::'
  preDeathDialogueLines:
  - portrait: {fileID: -5118401254094740915, guid: 9218ac208722d4fcd98dccbb34720a7b, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: You...
  - portrait: {fileID: -5118401254094740915, guid: 9218ac208722d4fcd98dccbb34720a7b, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: You were just like THE ARCHEA said...
  - portrait: {fileID: 6455895696698327629, guid: 9218ac208722d4fcd98dccbb34720a7b, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: I was meant to protect the whole world.
  - portrait: {fileID: -3021958138824128146, guid: 7517adc8717d94755af07be4738eec62, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: You and your specie have been killing everyone since you arrived...
  - portrait: {fileID: -4747953175934997105, guid: e730f1eaf609e4e4cbc321d8944c97b0, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: I understand THE ONE WHO RULES now...
  - portrait: {fileID: -4747953175934997105, guid: e730f1eaf609e4e4cbc321d8944c97b0, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: Jellies...
  - portrait: {fileID: 3206819849501703097, guid: e730f1eaf609e4e4cbc321d8944c97b0, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: Jellies are the real danger for Monera...
  - portrait: {fileID: 3206819849501703097, guid: e730f1eaf609e4e4cbc321d8944c97b0, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: YOU are the real DANGER for MONERA...
  - portrait: {fileID: 827771853864145743, guid: e730f1eaf609e4e4cbc321d8944c97b0, type: 3}
    interactSfx: {fileID: 0}
    interactSfxVolume: 0
    text: You are despicable...
  protectorTypeSfx: {fileID: 8300000, guid: 353ce1c21094e45e9bcdf8e707a1b8b9, type: 3}
  protectorTypeSfxVolume: 0.65
